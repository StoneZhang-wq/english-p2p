# 若 3000 已被其它项目占用，可改为 3010 等
PORT=3000
# 逗号分隔的前端来源，用于 CORS（须与浏览器访问来源完全一致，含 Cookie 登录）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# JWT 签发密钥：生产环境至少 16 字符，勿泄露
JWT_SECRET=change-me-to-a-long-random-string

# PostgreSQL（必填）。本地示例：postgresql://postgres:postgres@localhost:5432/p2p_chat
# Railway：添加 Postgres 插件后自动注入 DATABASE_URL
DATABASE_URL=

# 可选：连接池上限（默认 20）
# PG_POOL_MAX=20

# 生产环境（Railway 等 HTTPS）建议显式设置，以便 Cookie Secure
# NODE_ENV=production

# 仅在生产环境需要调试「POST /api/dev/pair-timeslot」时设为 1（有滥用风险，勿长期开启）
# ENABLE_DEV_PAIRING=

# 声网控制台：项目 → App ID；并开启 App Certificate（主证书）
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
