# 若 3000 已被其它项目占用，可改为 3010 等
PORT=3000
# 逗号分隔的前端来源，用于 CORS（须与浏览器访问来源完全一致，含 Cookie 登录）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# JWT 签发密钥：生产环境至少 16 字符，勿泄露
JWT_SECRET=change-me-to-a-long-random-string

# PostgreSQL（必填）。本地示例：postgresql://postgres:postgres@localhost:5432/p2p_chat
# Railway：添加 Postgres 插件后自动注入 DATABASE_URL
DATABASE_URL=

# 可选：连接池上限（默认 20）
# PG_POOL_MAX=20

# 生产环境（Railway 等 HTTPS）建议显式设置，以便 Cookie Secure
# NODE_ENV=production

# 管理员白名单（最小 RBAC）：逗号分隔 email（小写或大小写均可），例如：
# ADMIN_EMAILS=admin@example.com,ops@example.com

# 仅在生产环境需要调试「POST /api/dev/pair-timeslot」时设为 1（有滥用风险，勿长期开启）
# ENABLE_DEV_PAIRING=

# 生产 NODE_ENV=production 时：须 ENABLE_SANDBOX_LAB=1 才挂载沙箱 API，否则 dev-lab 无法加载数据。
# 若还要在开场前用 POST /api/dev/pair-timeslot 手动配对，须同时 ENABLE_DEV_PAIRING=1（可选，验收后关闭）。
# ENABLE_SANDBOX_LAB=1
# ENABLE_DEV_PAIRING=1

# 声网控制台：项目 → App ID；并开启 App Certificate（主证书）
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# LLM（OpenAI 兼容：豆包方舟等）。未配置、占位 Key 或模型为空时不调用，主题仍为轮换池静态数据。
# OPENAI_BASE_URL 可填完整 .../chat/completions，或只填网关前缀（代码会补全路径）。
# MODEL_PROVIDER 仅用于日志标识，可选。
# MODEL_PROVIDER=doubao
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# OPENAI_MODEL=
# 主题整包 JSON 较长，避免默认输出上限截断导致解析失败（可选，不设则服务端默认 8192）
# OPENAI_THEME_MAX_TOKENS=8192
